{
  "name": "easydocument",
  "version": "0.1.0",
  "private": true,
  "description": "EasyDocument enterprise monorepo scaffold.",
  "workspaces": [
    "apps/admin",
    "services/api",
    "packages/shared-types",
    "packages/shared-config"
  ],
  "scripts": {
    "dev:infra": "docker compose -f infra/docker/docker-compose.yml up -d",
    "stop:infra": "docker compose -f infra/docker/docker-compose.yml down",
    "logs:infra": "docker compose -f infra/docker/docker-compose.yml logs -f",
    "dev:api": "npm --workspace services/api run start:dev",
    "dev:admin": "npm --workspace apps/admin run dev",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "validate:production": "./scripts/validate-production-readiness.sh"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "@angular-devkit/core": {
      "ajv": "8.20.0",
      "picomatch": "4.0.4"
    },
    "@nestjs/cli": {
      "glob": "10.5.0",
      "webpack": "5.104.1"
    },
    "@nestjs/platform-express": {
      "body-parser": "1.20.5",
      "express": "4.22.2",
      "multer": "2.2.0"
    },
    "body-parser": {
      "qs": "6.15.2"
    },
    "express": {
      "qs": "6.15.2"
    },
    "lodash": "4.18.1"
  }
}
